body.theme-eye .main-toolbar {
    background: rgba(184, 201, 181, 0.95) !important;
}
body.theme-warm .main-toolbar {
    background: rgba(207, 197, 173, 0.95) !important;
}

/* 修复按钮背景统一 */
#addVolumeBtn, #addChapterBtn, #trashBtnHeader {
    background: #b8cab5 !important;
    border: none !important;
}
#trashBtnHeader {
    background: #dc3545 !important;
    color: white !important;
}
body.theme-dark #addVolumeBtn, body.theme-dark #addChapterBtn {
    background: #3a3a4a !important;
}
body.theme-dark #trashBtnHeader {
    background: #b52b3a !important;
}

/* 修复右侧边栏背景透明 */
